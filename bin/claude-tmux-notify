#!/usr/bin/env bash
#
# Claude Code hook -> tmux sessionizer bridge.
#
# Records the Claude state for the tmux session the hook is running inside, so
# the tmux_sessionizer picker and the tmux status bar can show a per-session
# indicator:
#
#   idle      -> orange  (Stop hook: finished a turn, awaiting your input)
#   working   -> blue    (UserPromptSubmit hook: you sent a prompt, Claude is busy)
#   attention -> red     (Notification hook: needs permission / has been waiting)
#   clear     ->         (SessionEnd hook: remove the marker)
#
# Wire it up in ~/.claude/settings.json, e.g.:
#   "Stop":             [{ "hooks": [{ "type": "command",
#                          "command": "\"$HOME/.local/bin/claude-tmux-notify\" idle" }] }]
#   "UserPromptSubmit": [{ "hooks": [{ "type": "command",
#                          "command": "\"$HOME/.local/bin/claude-tmux-notify\" working" }] }]
#   "Notification":     [{ "hooks": [{ "type": "command",
#                          "command": "\"$HOME/.local/bin/claude-tmux-notify\" attention" }] }]
#   "SessionEnd":       [{ "hooks": [{ "type": "command",
#                          "command": "\"$HOME/.local/bin/claude-tmux-notify\" clear" }] }]
#
# It is a no-op outside tmux, so it is safe to leave installed everywhere.

set -uo pipefail

state="${1:-}"
[[ -z "$state" ]] && exit 0

# The Notification hook fires both for "needs permission" (truly blocked) and
# for "waiting for your input" (just finished/idle). Read the hook's JSON from
# stdin and split: only a permission message becomes the orange "blocked" state,
# everything else is treated as plain green "idle". stdin is a pipe under a hook
# and a tty on a manual run, so -t guards against blocking.
if [[ "$state" == attention ]]; then
    msg=""
    [[ ! -t 0 ]] && msg=$(cat 2>/dev/null)
    case "$msg" in
        *permission*|*approve*) state=blocked ;;
        *)                      state=idle ;;
    esac
fi

# Nothing to do if we are not inside tmux.
[[ -z "${TMUX:-}" ]] && exit 0
command -v tmux &>/dev/null || exit 0

pane="${TMUX_PANE:-}"

# Resolve the session this hook is running in (via the inherited pane id).
session=$(tmux display-message ${pane:+-t "$pane"} -p '#{session_name}' 2>/dev/null) || exit 0
[[ -z "$session" ]] && exit 0

STATE_DIR="${XDG_RUNTIME_DIR:-/tmp}/tmux-sessionizer/state"
mkdir -p "$STATE_DIR"

# Slashes are the only session-name char that breaks the flat file layout.
safe_session="${session//\//_}"
f="$STATE_DIR/$safe_session"

# Skip redundant updates: PreToolUse fires "working" on every tool call, so if
# the state is unchanged don't rewrite, refresh, or re-notify.
if [[ "$state" != clear && -f "$f" && "$(<"$f")" == "$state" ]]; then
    exit 0
fi

case "$state" in
    clear)
        rm -f "$f"
        ;;
    idle|working|blocked)
        printf '%s' "$state" > "$f"
        ;;
    *)
        exit 0
        ;;
esac

# Force the status bar to repaint immediately instead of waiting for the
# status-interval tick.
tmux refresh-client -S 2>/dev/null

# --- desktop notification --------------------------------------------------
# At most one popup per session, updated in place (--replace-id) and dismissed
# the moment it is resolved: you send a new prompt, the session ends, or you are
# already looking at the pane. Soft urgency + themed icons keep it unobtrusive.
nid_file="$STATE_DIR/.nid_$safe_session"   # dot-prefixed: hidden from the * glob

close_notification() {
    [[ -f "$nid_file" ]] || return 0
    local id; id=$(<"$nid_file"); rm -f "$nid_file"
    [[ "$id" =~ ^[0-9]+$ ]] && command -v gdbus &>/dev/null \
        && gdbus call --session --dest org.freedesktop.Notifications \
            --object-path /org/freedesktop/Notifications \
            --method org.freedesktop.Notifications.CloseNotification "$id" &>/dev/null
    return 0
}

case "$state" in
    idle)      body="finished — awaiting you";   urgency=low ;;
    blocked)   body="blocked — needs permission"; urgency=normal ;;
    *)         close_notification; exit 0 ;;   # working / clear -> resolved
esac

command -v notify-send &>/dev/null || exit 0

# Don't ping the pane you're already looking at; dismiss any stale popup instead.
if [[ -n "$pane" ]]; then
    read -r att wact pact < <(tmux display-message -t "$pane" -p \
        '#{session_attached} #{window_active} #{pane_active}' 2>/dev/null)
    if [[ "${att:-0}" -gt 0 && "${wact:-0}" == 1 && "${pact:-0}" == 1 ]]; then
        close_notification
        exit 0
    fi
fi

replace=()
if [[ -f "$nid_file" ]]; then
    pid=$(<"$nid_file")
    [[ "$pid" =~ ^[0-9]+$ ]] && replace=(--replace-id "$pid")
fi

id=$(notify-send --app-name=claude --urgency="$urgency" --print-id \
    "${replace[@]}" \
    --hint=string:x-canonical-private-synchronous:"claude-$safe_session" \
    "${session##*__}" "$body")
[[ "$id" =~ ^[0-9]+$ ]] && printf '%s' "$id" > "$nid_file"

exit 0
