#!/usr/bin/env bash
#
# Switch the attached client to the Nth running Claude session, numbered as in
# the status bar (same glob order as tmux-claude-statusline). Bound to
# prefix + <n> in tmux.conf.   Usage: tmux-claude-switch N

set -uo pipefail

[[ -z "${TMUX:-}" ]] && exit 0
command -v tmux &>/dev/null || exit 0

idx="${1:-0}"
[[ "$idx" =~ ^[0-9]+$ ]] && (( idx > 0 )) || exit 0

STATE_DIR="${XDG_RUNTIME_DIR:-/tmp}/tmux-sessionizer/state"
[[ -d "$STATE_DIR" ]] || exit 0

declare -A real=()
while IFS= read -r s; do
    real["${s//\//_}"]="$s"
done < <(tmux list-sessions -F '#{session_name}' 2>/dev/null)

n=0
shopt -s nullglob
for f in "$STATE_DIR"/*; do
    sess="${real[$(basename "$f")]:-}"
    [[ -z "$sess" ]] && continue
    case "$(<"$f")" in idle|attention|working) ;; *) continue ;; esac
    if (( ++n == idx )); then
        tmux switch-client -t "$sess"
        exit 0
    fi
done
